# ── Personal CFO API configuration ─────────────────────────────────
# Copy to .env and fill in values. Everything runs in sandbox/simulated
# mode out of the box — add live keys only when you are ready.

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/personalcfo

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=90

# SMS / OTP adapter: "dev" logs the OTP and returns it in the API
# response (development only). "msg91" sends real SMS.
SMS_PROVIDER=dev
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Billing adapter: "sandbox" simulates Razorpay subscriptions.
# "razorpay" uses the live Subscriptions API.
BILLING_PROVIDER=sandbox
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Account Aggregator adapter: "mock" returns simulated consented data.
# "finvu" uses the Finvu AA gateway (requires FIU registration).
AA_PROVIDER=mock
FINVU_API_KEY=

# AI — Ask Your CFO
# Generation: Claude API. Leave blank to use the built-in deterministic
# financial answer engine (app stays fully functional without a key).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# RAG store is local (PostgreSQL) and per-user. No data leaves your
# infrastructure except the final prompt sent to the model.

# Email (monthly reports)
EMAIL_PROVIDER=dev
RESEND_API_KEY=
